# TransCraft Environment Variables

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key_here

# Langfuse Observability
ENABLE_LANGFUSE=true
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# MLflow Experiment Tracking
ENABLE_MLFLOW=true
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=transcraft_translation_quality

# Default Models
# Mini model is used for first-pass translation and quick evaluation
DEFAULT_MINI_MODEL=gpt-4o-mini
# Main model is used for styling and final review
DEFAULT_MAIN_MODEL=gpt-4o
